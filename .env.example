# Postgres (local Supabase or hosted). For Supabase, prefer the pooler URI; add ?sslmode=require if the client requires SSL.
DATABASE_URL=
BETTER_AUTH_SECRET=

# Vercel Cron → web/api/cron/pipeline.py (Authorization: Bearer …). Generate a long random string.
CRON_SECRET=

# Late-delivery inference: web/app/scoring/actions.ts → web/api/inference/run.py (Bearer). Required on Vercel.
INFERENCE_API_SECRET=

# Optional: absolute site URL for server-side fetch when VERCEL_URL is unset (e.g. local `vercel dev`)
# NEXT_PUBLIC_APP_URL=http://localhost:3000
INFERENCE_FUNCTION_URL=/api/run-inference
INFERENCE_TRIGGER_TOKEN=
LATE_DELIVERY_DECISION_THRESHOLD=0.5
