# Shared backend/frontend settings.
DATABASE_URL=
BETTER_AUTH_SECRET=

# Backend-only: secure /api/cron/pipeline if you use it.
CRON_SECRET=

# Shared secret between the frontend project and the backend FastAPI project.
INFERENCE_API_SECRET=
LATE_DELIVERY_DECISION_THRESHOLD=0.5

# Frontend-only: where the Next server action POSTs for scoring.
# Local (Option B — see README): run `bun run dev:api` from `web/`, then set:
# INFERENCE_FUNCTION_URL=http://127.0.0.1:3001/api/inference/run
# Production: your separate Vercel Python project, e.g.
INFERENCE_FUNCTION_URL=https://your-backend-project.vercel.app/api/inference/run
